# Token du bot Discord (à créer sur https://discord.com/developers/applications)
DISCORD_TOKEN=ton_token_ici

# Clé API Gemini – gratuit : https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# MongoDB (obligatoire sur Railway si tu utilises une base ; en local optionnel)
# Sur Railway : ajoute la variable MONGO_URL fournie par le service MongoDB
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/bot_sayuri

# Optionnel : ID du salon où le bot répond (laisser vide = répond partout quand on le mentionne)
# CHANNEL_IDS=123456789,987654321
